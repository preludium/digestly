<?xml version="1.0" encoding="UTF-8"?>
<opml version="2.0">
  <head>
    <title>E2E Fixture OPML - already subscribed</title>
  </head>
  <body>
    <outline text="Software Engineering" title="Software Engineering">
      <!-- Matches FIXTURE.rss in web/e2e/support/api.ts. Subscribe a user to it first so the
           import preview marks this row already_subscribed:true (backend/src/routes/opml.rs). -->
      <outline type="rss" text="E2E Fixture RSS Feed" title="E2E Fixture RSS Feed" xmlUrl="http://localhost:8098/rss.xml"/>
      <outline type="atom" text="E2E Fixture Atom Feed" title="E2E Fixture Atom Feed" xmlUrl="http://localhost:8098/atom.xml"/>
    </outline>
  </body>
</opml>
