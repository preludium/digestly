{
    "$schema": "https://biomejs.dev/schemas/2.5.3/schema.json",
    "vcs": {
        "enabled": true,
        "clientKind": "git",
        "useIgnoreFile": false
    },
    "files": {
        "includes": ["**", "!!**/dist", "!!**/node_modules"]
    },
    "formatter": {
        "enabled": true,
        "indentStyle": "space",
        "indentWidth": 4
    },
    "linter": {
        "enabled": true,
        "rules": {
            "preset": "recommended",
            "complexity": {
                "noExcessiveLinesPerFunction": "error"
            },
            "style": {
                "noExcessiveLinesPerFile": "error"
            }
        }
    },
    "javascript": {
        "formatter": {
            "quoteStyle": "double"
        }
    },
    "css": {
        "parser": {
            "tailwindDirectives": true
        }
    },
    "overrides": [
        {
            "includes": ["src/components/ui/**"],
            "linter": {
                "rules": {
                    "complexity": {
                        "noExcessiveLinesPerFunction": "off"
                    },
                    "style": {
                        "noExcessiveLinesPerFile": "off"
                    }
                }
            }
        },
        {
            "includes": ["public/sw.js"],
            "linter": {
                "rules": {
                    "complexity": {
                        "noExcessiveLinesPerFunction": "off"
                    }
                }
            }
        }
    ],
    "assist": {
        "enabled": true,
        "actions": {
            "source": {
                "organizeImports": "on"
            }
        }
    }
}
