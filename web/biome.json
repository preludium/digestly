{
    "$schema": "https://biomejs.dev/schemas/2.5.3/schema.json",
    "vcs": {
        "enabled": true,
        "clientKind": "git",
        "useIgnoreFile": false
    },
    "files": {
        "includes": [
            "**",
            "!!**/dist",
            "!!**/node_modules",
            "!!src/components/ui"
        ]
    },
    "formatter": {
        "enabled": true,
        "indentStyle": "space",
        "indentWidth": 4
    },
    "linter": {
        "enabled": true,
        "rules": {
            "preset": "recommended",
            "complexity": {
                "noExcessiveLinesPerFunction": {
                    "level": "error",
                    "options": {
                        "maxLines": 50,
                        "skipBlankLines": true,
                        "skipIifes": true
                    }
                }
            },
            "style": {
                "noExcessiveLinesPerFile": {
                    "level": "error",
                    "options": {
                        "maxLines": 300,
                        "skipBlankLines": true
                    }
                }
            }
        }
    },
    "javascript": {
        "formatter": {
            "quoteStyle": "double"
        }
    },
    "css": {
        "parser": {
            "tailwindDirectives": true
        }
    },
    "assist": {
        "enabled": true,
        "actions": {
            "source": {
                "organizeImports": "on"
            }
        }
    }
}
